# ====================================
# Pocket NOC Agent - Environment Config
# ====================================
# Para usar, copie este arquivo para .env e preencha os valores

# JWT Secret - CRÍTICO: Mínimo 32 bytes em produção
# Gere com: openssl rand -base64 32
POCKET_NOC_SECRET=your-secret-key-minimum-32-bytes-must-be-set-in-production

# API Key para fallback de autenticação (também mínimo 32 bytes)
# POCKET_NOC_API_KEY=your-api-key-here

# Porta do servidor (padrão: 9443)
# POCKET_NOC_PORT=9443

# Nível de logging (padrão: info)
# POCKET_NOC_LOG_LEVEL=info

# Tailscale/WireGuard (opcional)
# POCKET_NOC_USE_WIREGUARD=false
# POCKET_NOC_WIREGUARD_ENDPOINT=wg0

# Certificados TLS (em produção, use Let's Encrypt)
# POCKET_NOC_CERT_PATH=certs/cert.pem
# POCKET_NOC_KEY_PATH=certs/key.pem

# ====================================
# Notificações ntfy.sh
# ====================================
# Tópico do ntfy (gerado automaticamente a partir do secret se não definido)
# NTFY_TOPIC=pocket-noc-alerts

# ====================================
# Watchdog & Auto-Remediação
# ====================================

# Identificador único desta instância do agente — aparece em todos os alertas
# Exemplos: vps-deploy-01 | erp-server | db-primary | staging-01
SERVER_ID=vps-deploy-01

# Perfil do servidor — define quais probes são ativados automaticamente:
#   wordpress  → nginx/nginx, mysql, php8.1-fpm, HTTP :80, TCP :3306
#   erp        → gunicorn, postgresql, nginx, HTTP :8000 (ERP), HTTP :3000 (Next.js), TCP :5432
#   database   → mysql, postgresql, TCP :3306, TCP :5432
#   generic    → nginx, docker, pocket-noc-agent
SERVER_ROLE=wordpress

# Intervalo entre ciclos de verificação em segundos (padrão: 30)
# WATCHDOG_INTERVAL_SECS=30

# Máximo de falhas consecutivas antes de abrir o Circuit Breaker (padrão: 3)
# WATCHDOG_MAX_FAILURES=3

# Tempo de cooldown em segundos após abrir o Circuit Breaker (padrão: 300 = 5 min)
# WATCHDOG_COOLDOWN_SECS=300

# URL para receber eventos JSON do Watchdog (opcional — para server-controller ou third-party)
# WATCHDOG_WEBHOOK_URL=https://seu-controlador.com/api/watchdog/ingest

# ====================================
# Exemplos por servidor (remova os comentários no .env real)
# ====================================

# --- Servidor WordPress (Hosting) ---
# SERVER_ID=vps-deploy-01
# SERVER_ROLE=wordpress

# --- Servidor ERP Python / Next.js ---
# SERVER_ID=erp-server-01
# SERVER_ROLE=erp

# --- Servidor de Banco de Dados ---
# SERVER_ID=db-primary-01
# SERVER_ROLE=database

# ====================================
# Controller (Android/Kotlin)
# ====================================

# URL do servidor Pocket NOC
# CONTROLLER_API_URL=https://localhost:9443

# Token JWT para testes
# CONTROLLER_JWT_TOKEN=your-test-token-here

# ====================================
# Desenvolvimento apenas - NUNCA em produção
# ====================================
RUST_BACKTRACE=1
RUST_LOG=debug
