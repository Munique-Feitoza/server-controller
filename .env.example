# ====================================
# Pocket NOC Agent - Environment Config
# ====================================
# Para usar, copie este arquivo para .env e preencha os valores

# JWT Secret - CRÍTICO: Mínimo 32 bytes em produção
# Gere com: openssl rand -base64 32
POCKET_NOC_SECRET=your-secret-key-minimum-32-bytes-must-be-set-in-production

# API Key para fallback de autenticação (também mínimo 32 bytes)
# POCKET_NOC_API_KEY=your-api-key-here

# Porta do servidor (padrão: 9443)
# POCKET_NOC_PORT=9443

# Nível de logging (padrão: info)
# POCKET_NOC_LOG_LEVEL=info

# Tailscale/WireGuard (opcional)
# POCKET_NOC_USE_WIREGUARD=false
# POCKET_NOC_WIREGUARD_ENDPOINT=wg0

# Certificados TLS (em produção, use Let's Encrypt)
# POCKET_NOC_CERT_PATH=certs/cert.pem
# POCKET_NOC_KEY_PATH=certs/key.pem

# ====================================
# Controller (Android/Kotlin)
# ====================================

# URL do servidor Pocket NOC
# CONTROLLER_API_URL=https://localhost:9443

# Token JWT para testes
# CONTROLLER_JWT_TOKEN=your-test-token-here

# ====================================
# Desenvolvimento apenas - NUNCA em produção
# ====================================
RUST_BACKTRACE=1
RUST_LOG=debug
