# ======================================================
# domain-monitor — modelo de configuração
# Copie para .env e preencha. Use ASPAS SIMPLES nos valores
# (protege caracteres especiais de tokens/senhas).
# ======================================================

# Token(s) de API da Cloudflare — escopo Zone:Read.
# Várias contas: separe os tokens por vírgula. Ex.: CF_API_TOKEN='tokenA,tokenB'
CF_API_TOKEN='seu_token_da_cloudflare'

# ID da planilha do Google — SOMENTE o trecho entre /d/ e /edit da URL
SPREADSHEET_ID='id_da_planilha'

# Nome EXATO da aba de destino (a aba precisa já existir na planilha)
SHEET_NAME='Domínios'

# Caminho do credentials.json da Service Account (relativo à pasta domain-monitor/)
GOOGLE_CREDENTIALS='../credentials.json'

# Caminho do servers.json exigido pelo whois-rust
WHOIS_SERVERS='servers.json'

# Opcionais (têm default no código)
# WHOIS_DELAY_MS='1500'
# HTTP_TIMEOUT_SECS='30'
RUST_LOG='info'

# ======================================================
# Google Calendar — avisos diários de expiração (opcional)
# ======================================================
# Ativa a etapa de calendário. Default 'false'.
CALENDAR_ENABLED='false'

# ID do calendário onde os eventos serão criados. Para o calendário PRINCIPAL,
# é o seu e-mail do Google (ex.: 'voce@gmail.com'). Para um calendário dedicado,
# pegue em Configurações do calendário -> "Integrar calendário" -> ID do calendário.
# IMPORTANTE: compartilhe esse calendário com o e-mail da Service Account
# (client_email do credentials.json), permissão "Fazer alterações nos eventos".
CALENDAR_ID=''

# Cria/gerencia o evento quando faltam <= N dias para expirar. Default 14.
# CALENDAR_ALERT_DAYS='14'

# Quantos dias seguidos avisar (recorrência diária) no fim. Default 7 (1 semana).
# CALENDAR_NAG_DAYS='7'
